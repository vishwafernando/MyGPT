# Backend Environment Variables Template for Local Development
# Copy this file to .env and fill in your actual values

# Server Configuration (Local Development)
PORT=5000

# Database Configuration
# Get from MongoDB Atlas or use local: mongodb://localhost:27017/mygpt
MONGO_URL=your_mongodb_connection_string_here

# ImageKit Configuration
# Get from https://imagekit.io/dashboard/developer/api-keys
IMAGE_KIT_ENDPOINT=your_imagekit_endpoint_here
IMAGE_KIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGE_KIT_PRIVATE_KEY=your_imagekit_private_key_here

# Clerk Authentication
# Get from https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Example filled values (replace with your actual values):
# MONGO_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/mygpt
# IMAGE_KIT_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
# IMAGE_KIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxx
# IMAGE_KIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxx
# CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxx
